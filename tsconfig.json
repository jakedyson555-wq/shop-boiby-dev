{
  "compilerOptions": {
      "target": "ESNext",
      "module": "esnext",
      "moduleResolution": "bundler",
      "jsx": "react-jsx",
      "strict": false,
      "noEmit": true,
      "skipLibCheck": true,
      "allowJs": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "allowSyntheticDefaultImports": true,
      "types": ["node"],
      "baseUrl": "."
    },
    "include": ["src", "vite.config.ts", "src/vite-env.d.ts"],
    "exclude": ["node_modules", "dist"],
  }
  